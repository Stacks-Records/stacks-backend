{
    "version": 2,
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/import-albums",
            "schedule": "0 12 * * *"
        }
    ],
    "functions": {
        "api/index.js": {
            "maxDuration": 60
        }
    }
}
